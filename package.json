{
  "name": "quran-video-maker",
  "version": "1.0.0",
  "description": "Lecteur Quran local dans Electron",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:web": "node scripts/build-web.js"
  },
  "dependencies": {
    "quran-search-engine": "^0.3.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.qvm.player",
    "productName": "QuranVideoMaker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "logo-build.png",
      "signAndEditExecutable": false
    },
    "files": [
      "electron/**",
      "index.html",
      "sw.js",
      "logo.png",
      "manifest.webmanifest",
      "icons/**",
      "qul/**",
      "local_audio/**",
      "online/**"
    ]
  }
}
